{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Nexus — local-first knowledge base (Obsidian-форк, Tauri 2 + Rust + React)",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @nexus/desktop app:dev",
    "build": "pnpm --filter @nexus/desktop build",
    "build:app": "pnpm --filter @nexus/desktop app:build",
    "preview": "pnpm --filter @nexus/desktop preview",
    "test": "pnpm -r --if-present test",
    "e2e": "playwright test --config apps/desktop/e2e/playwright.config.ts",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:coverage": "pnpm -r --if-present test:coverage"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
